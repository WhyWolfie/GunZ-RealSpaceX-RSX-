	  res_sex="m" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="This mystical gem unlocks the bestial nature that slumbers in each of us." />
	<ITEM id="1220" name="Paladin Armor" type="avatar" slot="avatar" avatar_head="eq_head_holyarmor"
	  avatar_chest="eq_chest_holyarmor" avatar_hand="eq_hands_holyarmor" avatar_legs="eq_legs_holyarmor" avatar_feet="eq_feet_holyarmor"
	  res_sex="m" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="This fine armor is crafted from concentrated quicksilver, solidified by magic. It was traditionally worn only by the highest-ranking knights of the Axium Empire's Templars, but a few sets became available on the black market after rebels broke into the Empire's armory." />
	<ITEM id="1221" name="Cursed Bandage (Men)" type="avatar" slot="avatar" avatar_head="eq_head_mummy"
	  avatar_chest="eq_chest_mummy" avatar_hand="eq_hands_mummy" avatar_legs="eq_legs_mummy" avatar_feet="eq_feet_mummy"
	  res_sex="m" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="These ominous bandage wraps were discovered during the excavatation of the King’s Tomb.  Touching it seems to summon a putrid breeze carrying angry whispers in an ancient tongue." />
	<ITEM id="1222" name="Blue Crystals (Men)" type="avatar" slot="avatar" avatar_head="eq_head_iceelemental"
	  avatar_chest="eq_chest_iceelemental" avatar_hand="eq_hands_iceelemental" avatar_legs="eq_legs_iceelemental" avatar_feet="eq_feet_iceelemental"
	  res_sex="m" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="Mysterious beings with exoskeletons made of crystals the color and temperature of ice." />

