	  bt_price="500000" maxwt="0" sf="0" fr="0" cr="0" pr="0" lr="0" color="#FFFFFFFF" desc="A coat favored by the Black Knights, a group of battle-hungry crusaders fighting the criminal gangs of the Republic's underworld." />
	<ITEM id="694" name="Guerrilla Commando Uniform Jacket" mesh_name="eq_chest_gleader" totalpoint="0" 
