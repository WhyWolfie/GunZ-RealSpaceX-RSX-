	  res_sex="m" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="A scarecrow with some secret energy that allows it to hold the souls of people. " />
	<ITEM id="1217" name="Shadow Suit (Men)" type="avatar" slot="avatar" avatar_head="eq_head_sknight"
