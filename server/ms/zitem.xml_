	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="This Avatar, shaped by the Shadow of the Dark Age, transforms into body armor when equipped. It once had supernatural powers but now only possesses transformative power. " />
	<ITEM id="1224" name="Dried Brain (Women)" type="avatar" slot="avatar" avatar_head="eq_head_zombie"
	  avatar_chest="eq_chest_zombie" avatar_hand="eq_hands_zombie" avatar_legs="eq_legs_zombie" avatar_feet="eq_feet_zombie"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="A mysterious artifact found in the ruins of the northern continent. Legend has it that this item will give an immortal body to anyone that possess it." />
	<ITEM id="1225" name="Battle Suit (Women)" type="avatar" slot="avatar" avatar_head="eq_head_battlesuit"
	  avatar_chest="eq_chest_battlesuit" avatar_hand="eq_hands_battlesuit" avatar_legs="eq_legs_battlesuit" avatar_feet="eq_feet_battlesuit"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="Next-generation personal battle equipment made by Adam Industry. Only a few prototype versions exist." />
	<ITEM id="1226" name="Hunter Uniform (Women)" type="avatar" slot="avatar" avatar_head="eq_head_shunter"
	  avatar_chest="eq_chest_shunter" avatar_hand="eq_hands_shunter" avatar_legs="eq_legs_shunter" avatar_feet="eq_feet_shunter"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="Initial version of the uniform provided to the outstanding hunters recognized by the Hunter’s union." />
	<ITEM id="1227" name="Gem of Forest (Women)" type="avatar" slot="avatar" avatar_head="eq_head_dryad"
	  avatar_chest="eq_chest_dryad" avatar_hand="eq_hands_dryad" avatar_legs="eq_legs_dryad" avatar_feet="eq_feet_dryad"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="A gem with the blessing of the forest. The one who possesses this gem will be transformed into a forest fairy by the sprit of the trees." />
	<ITEM id="1228" name="Invisibility Suit (Women)" type="avatar" slot="avatar" avatar_head="eq_head_invisible"
	  avatar_chest="eq_chest_invisible" avatar_hand="eq_hands_invisible" avatar_legs="eq_legs_invisible" avatar_feet="eq_feet_invisible"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="A mysterious Invisibility Suit that an unknown researcher dedicated his entire life to make. Unfortunately, no one knows how to make the suit anymore." />
	<ITEM id="1229" name="Bloody Battle Suit (Women)" type="avatar" slot="avatar" avatar_head="eq_head_bloodsuit"
	  avatar_chest="eq_chest_bloodsuit" avatar_hand="eq_hands_bloodsuit" avatar_legs="eq_legs_bloodsuit" avatar_feet="eq_feet_bloodsuit"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="A lean-shaped new type of battle suit made by Adam Industry. It is still in its prototype stage.  " />
	<ITEM id="1230" name="Scarecrow (Women)" type="avatar" slot="avatar" avatar_head="eq_head_scarecrow"
	  avatar_chest="eq_chest_scarecrow" avatar_hand="eq_hands_scarecrow" avatar_legs="eq_legs_scarecrow" avatar_feet="eq_feet_scarecrow"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="A scarecrow with some secret energy that allows it to hold the souls of people. " />
	<ITEM id="1231" name="Shadow Suit (Women)" type="avatar" slot="avatar" avatar_head="eq_head_sknight"
	  avatar_chest="eq_chest_sknight" avatar_hand="eq_hands_sknight" avatar_legs="eq_legs_sknight" avatar_feet="eq_feet_sknight"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="A combat uniform of the Secret Imperial special force 'Shadow Knights.'" />
	<ITEM id="1232" name="Cursed Blood (Women)" type="avatar" slot="avatar" avatar_head="eq_head_vampire"
	  avatar_chest="eq_chest_vampire" avatar_hand="eq_hands_vampire" avatar_legs="eq_legs_vampire" avatar_feet="eq_feet_vampire"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="A glass bottle filled with dark red blood. Dismal, inhuman energy surrounds the bottle." />
	<ITEM id="1233" name="Moonstone" type="avatar" slot="avatar" avatar_head="eq_head_wolfman"
	  avatar_chest="eq_chest_wolfman" avatar_hand="eq_hands_wolfman" avatar_legs="eq_legs_wolfman" avatar_feet="eq_feet_wolfman"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="This mystical gem unlocks the bestial nature that slumbers in each of us." />
	<ITEM id="1234" name="Saint Armor" type="avatar" slot="avatar" avatar_head="eq_head_holyarmor"
	  avatar_chest="eq_chest_holyarmor" avatar_hand="eq_hands_holyarmor" avatar_legs="eq_legs_holyarmor" avatar_feet="eq_feet_holyarmor"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="This fine armor is crafted from concentrated quicksilver, solidified by magic. It was traditionally worn only by the highest-ranking knights of the Axium Empire's Templars, but a few sets became available on the black market after rebels broke into the Empire's armory." />
	<ITEM id="1235" name="Cursed Bandage (Women)" type="avatar" slot="avatar" avatar_head="eq_head_mummy"
	  avatar_chest="eq_chest_mummy" avatar_hand="eq_hands_mummy" avatar_legs="eq_legs_mummy" avatar_feet="eq_feet_mummy"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="These ominous bandage wraps were discovered during the excavatation of the King’s Tomb.  Touching it seems to summon a putrid breeze carrying angry whispers in an ancient tongue." />
	<ITEM id="1236" name="Blue Crystals (Women)" type="avatar" slot="avatar" avatar_head="eq_head_iceelemental"
	  avatar_chest="eq_chest_iceelemental" avatar_hand="eq_hands_iceelemental" avatar_legs="eq_legs_iceelemental" avatar_feet="eq_feet_iceelemental"
	  res_sex="f" res_level="0" bt_price="500000" iscashitem="false" weight="0" desc="Mysterious beings with exoskeletons made of crystals the color and temperature of ice." />

	  
